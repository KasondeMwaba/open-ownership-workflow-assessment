# Docker Compose / local deployment example.
# Copy to .env for local overrides. Do not commit real secrets.

POSTGRES_DB=workflow
POSTGRES_USER=workflow
POSTGRES_PASSWORD=change-me

API_PORT=18080
API_INTERNAL_PORT=8080
FRONTEND_PORT=5173

DATABASE_URL=postgres://workflow:change-me@postgres:5432/workflow?sslmode=disable
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:18080

SEED_REQUESTER_NAME=Amina Requester
SEED_REQUESTER_EMAIL=requester@example.com
SEED_REQUESTER_PASSWORD=password
SEED_REVIEWER_NAME=Noah Reviewer
SEED_REVIEWER_EMAIL=reviewer@example.com
SEED_REVIEWER_PASSWORD=password
SEED_ADMIN_NAME=Sam Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password
